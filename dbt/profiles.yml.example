chicago_taxi_analytics:
  target: prod
  outputs:
    prod:
      type: bigquery
      method: oauth
      project: "{{ env_var('DBT_BIGQUERY_PROJECT') }}"
      dataset: "{{ env_var('ANALYTICS_DATASET', 'analytics') }}"
      location: US
      threads: 4
      job_execution_timeout_seconds: 300
      job_retries: 1

